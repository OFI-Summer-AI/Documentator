DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,.up.railway.app,.railway.internal,.railway.app
TIME_ZONE=UTC

POSTGRES_DB=backend_template
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:postgres@db:5432/backend_template
USE_SQLITE_FOR_DEMO=False

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini


CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend.vercel.app
CORS_ALLOW_CREDENTIALS=True
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend.vercel.app

JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7
DJANGO_SECURE_SSL_REDIRECT=False
